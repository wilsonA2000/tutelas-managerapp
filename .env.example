# Tutelas Manager - Variables de Entorno
# Copiar a .env y llenar con valores reales
# NUNCA commitear .env al repositorio

# Ruta base donde estan las carpetas de tutelas (ejemplos por SO):
#   Linux/macOS:  /home/usuario/tutelas
#   Windows:      C:\Users\Usuario\Documents\tutelas
#   WSL:          /mnt/c/Users/Usuario/Documents/tutelas
BASE_DIR=/path/to/tutelas/folders

# Gmail API (OAuth2). Requiere credenciales descargadas de Google Cloud Console.
# El archivo gmail_credentials.json va junto a este .env (NO se commitea).
GMAIL_USER=tu_email@dominio.com

# Proveedores IA (v5.4: solo 2 activos)
# DeepSeek — primario, razonamiento + extracción (ultra barato, ~$0.28/1M tokens)
DEEPSEEK_API_KEY=sk-...

# Anthropic Claude Haiku 4.5 — fallback pagado (~$1/1M input)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================
# PII Redaction (v5.3) — capa de anonimización pre-IA externa
# ============================================================
# Llave maestra para cifrar mapeos token↔valor en tabla pii_mappings.
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# OBLIGATORIA si PII_REDACTION_ENABLED=true.
PII_MASTER_KEY=

# Modo por defecto: "selective" (solo identificadores numéricos) o "aggressive" (también nombres).
# El operador puede sobrescribir por caso vía toggle UI.
PII_MODE_DEFAULT=selective

# true = bloquear envío a IA si gate detecta PII remanente. false = solo loggear (modo warn, útil en calibración inicial).
PII_GATE_STRICT=true

# Modelo spaCy ES. "md" (40MB) recomendado; "lg" (550MB) mejor recall pero pesado.
PII_PRESIDIO_MODEL=es_core_news_md
